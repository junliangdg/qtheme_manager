# -------------------------------
# Modern EditorConfig for C/C++ Projects
# Ensures UTF-8 encoding, consistent style
# -------------------------------

# top-most EditorConfig file
root = true

# -------------------------------
# All files
# -------------------------------
[*]
# Use UTF-8 encoding
charset = utf-8
# Unix-style line endings
end_of_line = lf
# Trim trailing whitespace
trim_trailing_whitespace = true
# Insert final newline at end of file
insert_final_newline = true

# -------------------------------
# C/C++ source and header files
# -------------------------------
[*.{c,cpp,h,hpp}]
# UTF-8 encoding (redundant, but explicit for clarity)
charset = utf-8
# 4-space indentation (common modern C++ style)
indent_style = space
indent_size = 4
# No tab characters
tab_width = 4
# Ensure consistent line endings
end_of_line = lf
# Insert final newline
insert_final_newline = true
# Trim trailing whitespace
trim_trailing_whitespace = true

# -------------------------------
# Optional: Markdown/Documentation files
# -------------------------------
[*.md]
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
insert_final_newline = true
end_of_line = lf
